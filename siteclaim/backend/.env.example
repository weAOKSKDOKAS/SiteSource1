# SiteSource backend configuration — copy to backend/.env and fill in.
# backend/.env is gitignored; NEVER commit a real key. DEMO_MODE needs no key.

# Offline demo: when true, the whole pipeline reads fixtures and the seeded DB and
# makes zero network calls and loads no model. Set to false to run the live engine.
DEMO_MODE=true

# --- Layer 2 (Claude) — live ingest / compose / parse -----------------------
# Extraction / composition provider for the Layer 2 stages.
EXTRACTION_PROVIDER=anthropic

# Required when EXTRACTION_PROVIDER=anthropic (live ingest / compose only).
ANTHROPIC_API_KEY=
# Optional model override (defaults to the pinned Claude model in llm_client.py).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional OpenAI-compatible alternative (text-only; cannot read document images).
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-pro

# --- Phase A live engine ----------------------------------------------------
# Real email-out (Stage 03). Leave SMTP_HOST empty to keep the mock outbox: with no
# host, or in DEMO_MODE, or with dry_run=true on /dispatch, nothing is ever sent —
# bundles are only recorded. Fill these to send real RFQ emails with attachments.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_STARTTLS=true
# SMTP_USER=buying-team@example.com
# SMTP_PASSWORD=
# SMTP_FROM=buying-team@example.com

# Where live tender originals and generated SoR sheets are stored, so dispatch can
# attach the real files. Defaults to backend/fixtures/out/workspace (gitignored).
# SITESOURCE_WORKDIR=/var/lib/sitesource/workspace

# --- Gmail integration (drafts out + reply polling in) -----------------------
# MIGRATION: N8N_DRAFTS_WEBHOOK was removed — the backend talks to the Gmail API
# directly now (n8n was the failing transport on both directions; delete the two n8n
# workflows). See docs/EMAIL_SETUP.md for the one-time OAuth setup.
# OAuth client from the operator's Google Cloud project (Gmail API enabled; consent
# screen PUBLISHED to Production — a Testing screen expires refresh tokens in 7 days).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Token file the one-time consent flow writes (`python -m pipeline.gmail_client`) and
# the backend then refreshes automatically. Gitignored; default backend/.gmail_token.json.
# GMAIL_TOKEN_PATH=
# One JSONL line per Gmail call (draft created / poll results / errors) for debugging.
# SITESOURCE_GMAIL_LOG=gmail_calls.jsonl

# --- OCR (scanned tender documents) -----------------------------------------
# Scanned SoR/PS/MM PDFs (no text layer) are read by local tesseract OCR so the
# clause-slicing assembler finds markers and DeepSeek reads the priced rows cheaply
# (needs the system `tesseract-ocr` binary; pytesseract is imported lazily). Never
# runs on the DEMO path. OCR_ENABLED=false reverts to the native-text + vision path
# exactly (fully reversible). The cache is content-addressed on the file bytes and
# defaults to a subdir of SITESOURCE_WORKDIR.
# OCR_ENABLED=true
# OCR_DPI=300
# OCR_LANG=eng
# SITESOURCE_OCR_CACHE=/var/lib/sitesource/ocr_cache
# Path to the tesseract binary. Empty = auto-detect (common install locations, then
# PATH); set it when tesseract is installed but not on the service's PATH (e.g. on
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe).
# TESSERACT_CMD=

# Which database the engine opens. Leave unset for the packaged demo DB
# (sitesource.db, 150 firms). Point it at the clean live DB (build it with
# `python -m db.seed --profile live`) so the live engine runs on real firms only.
# SITESOURCE_DB=db/sitesource_live.db
